<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Define properties -->
    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width" value="0.4" />
    <xacro:property name="base_height" value="0.2" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />
    <xacro:property name="stand_pillar_radius" value="0.01" />
    <xacro:property name="stand_pillar_length" value="0.23" />

    <!-- Base footprint -->
    <link name="base_footprint" />

    <!-- Base link -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
            <material name="green" />
        </visual>
        <xacro:cylinder_inertia m="5.0" r="${base_length}" h="${base_height}" 
                                xyz="0 0 ${2 * base_height / 2.0}" rpy="0 0 0" />
        <collision>
            <geometry>
                <box size="0.6 0.4 0.2" />
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Lidar link -->
    <link name="lidar">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="white" />
        </visual>
        <collision>
            <geometry>
                <box size="0.2 0.2 0.05" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
    </link>

    <!-- Wheel link macro -->
    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="gray" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" h="${wheel_length}"
                                    xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        </link>
    </xacro:macro>

    <!-- Wheel link instances -->
    <xacro:wheel_link prefix="right_front" />
    <xacro:wheel_link prefix="left_front" />
    <xacro:wheel_link prefix="right_back" />
    <xacro:wheel_link prefix="left_back" />

    <!-- Stand macro -->
    <xacro:macro name="stand_pillar" params="prefix">
        <link name="${prefix}_stand_pillar">
            <visual>
                <geometry>
                    <cylinder radius="${stand_pillar_radius}" length="${stand_pillar_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <material name="black" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${stand_pillar_radius}" length="${stand_pillar_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${stand_pillar_radius}" h="${stand_pillar_length}"
                                    xyz="0 0 0" rpy="0 0 0" />
        </link>
    </xacro:macro>

    <!-- Stand pillar instances -->
    <xacro:stand_pillar prefix="right_up" />
    <xacro:stand_pillar prefix="right_down" />
    <xacro:stand_pillar prefix="left_up" />
    <xacro:stand_pillar prefix="left_down" />

    <!-- base_footprint -->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
    </joint>

    <!-- Base to lidar joint -->
    <joint name="base_lidar_joint" type="fixed">
        <parent link="base_link" />
        <child link="lidar" />
        <origin xyz="0 0 0.3" rpy="0 0 0" />
    </joint>

    <!-- Wheel joints -->
    <joint name="base_left_wheel" type="continuous">
        <parent link="base_link" />
        <child link="left_front_wheel" />
        <origin xyz="-0.15 -0.225 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel" type="continuous">
        <parent link="base_link" />
        <child link="right_front_wheel" />
        <origin xyz="-0.15 0.225 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_left_back_wheel" type="continuous">
        <parent link="base_link" />
        <child link="left_back_wheel" />
        <origin xyz="0.15 -0.225 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_back_wheel" type="continuous">
        <parent link="base_link" />
        <child link="right_back_wheel" />
        <origin xyz="0.15 0.225 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- Stand pillar joints -->
    <joint name="stand_rightup_lidar" type="fixed">
        <parent link="base_link" />
        <child link="right_up_stand_pillar" />
        <origin xyz="0.0635 0.0635 0.2" rpy="0 0 0" />
    </joint>

    <joint name="stand_rightdown_lidar" type="fixed">
        <parent link="base_link" />
        <child link="right_down_stand_pillar" />
        <origin xyz="0.0635 -0.0635 0.2" rpy="0 0 0" />
    </joint>

    <joint name="stand_leftup_lidar" type="fixed">
        <parent link="base_link" />
        <child link="left_up_stand_pillar" />
        <origin xyz="-0.0635 0.0635 0.2" rpy="0 0 0" />
    </joint>

    <joint name="stand_leftdown_lidar" type="fixed">
        <parent link="base_link" />
        <child link="left_down_stand_pillar" />
        <origin xyz="-0.0635 -0.0635 0.2" rpy="0 0 0" />
    </joint>

</robot>
